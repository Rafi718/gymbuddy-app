# Database — PostgreSQL
# Option 1: Single connection URL (recommended for Railway/Render/etc.)
# DATABASE_URL=postgresql://user:password@host:5432/gymbuddy

# Option 2: Individual credentials
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=gymbuddy

# Set to true if your DB requires SSL (e.g. Railway, Aiven)
# DB_SSL=true

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Server
PORT=5000
NODE_ENV=production

# Frontend URL (for CORS)
FRONTEND_URL=https://frontend-three-bay-49.vercel.app

# Midtrans (Sandbox)
MIDTRANS_SERVER_KEY=SB-Mid-server-your-key
MIDTRANS_CLIENT_KEY=SB-Mid-client-your-key
MIDTRANS_IS_PRODUCTION=false
